@page "/cobranca"
@rendermode InteractiveServer
@using MediatR
@using Cob.Regressivo.Web.Features.CobrancaFlow.Application.BuscarContratos
@using Cob.Regressivo.Web.Features.CobrancaFlow.Application.ExecutarFluxo
@using Cob.Regressivo.Web.Features.CobrancaFlow.Domain
@inject IMediator Mediator
@inject CobrancaFlowState State
@implements IDisposable

<PageTitle>Gestão de Cobrança</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">

            <!-- Step indicator -->
            <div class="d-flex align-items-center mb-4">
                @for (int i = 0; i < _steps.Length; i++)
                {
                    var idx   = i;
                    var label = _steps[idx].Label;
                    var step  = _steps[idx].Step;
                    var ativo = State.CurrentStep == step;
                    var feito = (int)State.CurrentStep > (int)step;

                    @if (idx > 0)
                    {
                        <div class="flex-grow-1 mx-1" style="height:2px; background:@(feito || ativo ? "#0d6efd" : "#dee2e6")"></div>
                    }
                    <div class="d-flex flex-column align-items-center" style="min-width:52px">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                             style="width:34px;height:34px;font-size:13px;
                                    background:@(feito ? "#198754" : ativo ? "#0d6efd" : "#e9ecef");
                                    color:@(feito || ativo ? "#fff" : "#6c757d")">
                            @(feito ? "✓" : (idx + 1).ToString())
                        </div>
                        <small class="mt-1 text-center @(ativo ? "fw-bold text-primary" : "text-muted")" style="font-size:11px">@label</small>
                    </div>
                }
            </div>

            @switch (State.CurrentStep)
            {
                case FlowStep.EnterCpf:
                    <CpfInput OnCpfSubmitted="HandleCpfSubmitted" IsLoading="State.IsLoading" />
                    break;

                case FlowStep.ViewContracts:
                    <ContratoList Contratos="State.Contratos"
                                  OnSelectionConfirmed="HandleSelectionConfirmed"
                                  OnVoltar="State.Reiniciar" />
                    break;

                case FlowStep.SelectFluxo:
                    <FluxoSelector ContratosSelecionados="State.ContratosSelecionados"
                                   OnFluxoSelected="HandleFluxoSelected"
                                   OnVoltar="State.VoltarParaContratos" />
                    break;

                case FlowStep.Executing:
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" style="width:3rem;height:3rem" role="status"></div>
                        <p class="mt-3 text-muted fs-5">Processando operação...</p>
                    </div>
                    break;

                case FlowStep.ViewResult:
                    <Resultado ResultadoFluxo="State.Resultado!"
                               TipoFluxo="State.FluxoSelecionado!.Value"
                               OnReiniciar="State.Reiniciar" />
                    break;
            }
        </div>
    </div>
</div>

@code {
    private static readonly (string Label, FlowStep Step)[] _steps =
    [
        ("CPF",        FlowStep.EnterCpf),
        ("Contratos",  FlowStep.ViewContracts),
        ("Negociação", FlowStep.SelectFluxo),
        ("Resultado",  FlowStep.ViewResult),
    ];

    protected override void OnInitialized()
        => State.OnChange += StateHasChanged;

    private async Task HandleCpfSubmitted(string cpf)
    {
        State.IniciarBusca(cpf);
        var contratos = await Mediator.Send(new BuscarContratosPorCpfQuery(cpf));
        State.SetContratos(contratos);
    }

    private void HandleSelectionConfirmed(List<ContratoDto> selecionados)
        => State.ConfirmarSelecao(selecionados);

    private async Task HandleFluxoSelected(TipoFluxo fluxo)
    {
        State.IniciarExecucao(fluxo);
        var resultado = await Mediator.Send(
            new ExecutarFluxoCommand(State.Cpf!, State.ContratosSelecionados, fluxo));
        State.SetResultado(resultado);
    }

    public void Dispose()
        => State.OnChange -= StateHasChanged;
}
